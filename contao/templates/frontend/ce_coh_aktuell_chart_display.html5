<div id="cohPanel_<?= $this->chartId ?>" class="coh-panel">

    <?php
        $d = $this->data ?? [];
        //liefert Wert
        if (!function_exists('coh_v')) { function coh_v(array $d, string $id, $default = '-') { return $d[$id]['sensorValue'] ?? $default; } }
        //liefert Wert + Einheit
        if (!function_exists('coh_ve')) {
            function coh_ve(array $d, string $id, $default = '-') {
                $str = '';
                if (!empty($d[$id]['sensorValue'])) { $str .= $d[$id]['sensorValue'];
                } else { $str .= $default; }
                $str .= ' ' . ($d[$id]['sensorEinheit'] ?? '');
                return $str;
            }
        }    
        // Liefert Einheit
        if (!function_exists('coh_e')) {
            function coh_e(array $d, string $id, string $default = '') { return $d[$id]['sensorEinheit'] ?? $default;}
        }

        // Liefert Titel
        if (!function_exists('coh_title')) { function coh_title(array $d, string $id, string $default = '') { return $d[$id]['sensorTitle'] ?? $default; } }

        // macht aus value float
        if (!function_exists('coh_num')) {
            function coh_num($value, $default = 0.0): float
            {
                if ($value === null || $value === '' || $value === '-') { return (float) $default; }
                return (float) str_replace(',', '.', (string) $value);
            }
        }
    /*
     * Funktionen zur Berechnung bei Wasser und Leckage
     */

        // leckage test 
        function detectLeakType(array $d): array {
        // Werte sauber holen (fallbacks)
            $flow   = coh_num(coh_v($d, 'SyrFlo', 0), 0);
            $volume = coh_num(coh_v($d, 'SyrLtv', 0), 0);
            $alarm  = coh_v($d, 'SyrAla','ff');
            $warn   = coh_v($d, 'SyrWan','ff');
            $valve  = coh_v($d, 'SyrVlv',0);
            // kein Alarm → alles ok
            if (($alarm === 0 || $alarm === 'ff') && ($warn === 0 || $warn === 'ff')) {
                return [
                    'type' => 'none',
                    'text' => '✅ Kein Leck erkannt ',
                    'severity' => 'ok'
                ];
            }
            // 🔴 Rohrbruch / hoher Durchfluss
            if ($flow > 1000) {
                return [
                    'type' => 'flow',
                    'text' => '🔴 Hoher Durchfluss (Rohrbruch möglich)',
                    'severity' => 'critical'
                ];
            }
            // 🟠 Volumenleckage (viel Wasser aber kein hoher Flow)
            if ($volume > 50 && $flow < 1000) {
                return [
                    'type' => 'volume',
                    'text' => '🟠 Ungewöhnlich hoher Wasserverbrauch',
                    'severity' => 'warning'
                ];
            }
            // 🟡 Mikroleckage (kleiner Flow, aber Alarm/Warnung)
            if ($flow > 0 && $flow < 50) {
                return [
                    'type' => 'micro',
                    'text' => '🟡 Mikroleckage (kleiner Dauerfluss erkannt)',
                    'severity' => 'warning'
                ];
            }
            // 🟠 Ventil zu ohne klaren Grund → meist Mikroleckage oder Zeit
            if ($valve === 10) {
                return [
                    'type' => 'auto_closed',
                    'text' => '🟠 Ventil wurde automatisch geschlossen',
                    'severity' => 'critical'
                ];
            }
            // 🟣 Fallback
            return [
                'type' => 'unknown',
                'text' => "🟣 Unklare Leckage $alarm $warn",
                'severity' => 'warning'
            ];
        }
        // ---------------------------------------------------
        // WASSERHÄRTE rendering PUNKTE
        // ---------------------------------------------------
        function hardnessDots($dH){
            if($dH < 8) return "🟢⚪⚪";
            if($dH < 14) return "🟢🟡⚪";
            return "🟢🟡🔴";
        }
        // ---------------------------------------------------
        // LISTEN werte extrahieren
        // ---------------------------------------------------
        function decodeList($str){
            if(!$str) return [];
            return array_filter(array_map('trim', explode(",", $str)));
        }
        // ---------------------------------------------------
        // ALARM
        // ---------------------------------------------------
        function decodeAlarm($hex) {
            if (!$hex || strtolower($hex) == "ff") return ["(FF) Kein aktueller Alarm","ok"];
            $hex = strtoupper(trim((string)$hex));
            if (strpos($hex, "0X") !== 0) $hex = "0x".$hex;
            $map = [
                "0xFF" => ["(FF) Kein Alarm","ok"],
                "0xA1" => ["(A1) Endschalter Problem","alarm"],
                "0xA2" => ["(A2) Motorstrom zu hoch","alarm"],
                "0xA3" => ["(A3) Volumenleckage","alarm"],
                "0xA4" => ["(A4) Zeitleckage","alarm"],
                "0xA5" => ["(A5) Durchflussleckage","alarm"],
                "0xA6" => ["(A6) Mikroleckage","warn"],
                "0xA7" => ["(A7) Bodensensor-Leckage","alarm"],
                "0xA8" => ["(A8) Durchflusssensor defekt","alarm"],
                "0xA9" => ["(A9) Drucksensor defekt","alarm"],
                "0xAA" => ["(AA) Temperatursensor defekt","alarm"],
                "0xAB" => ["(AB) Leitwertsensor defekt","alarm"],
                "0xAC" => ["(AC) Leitwertsensor Fehler","alarm"],
                "0xAD" => ["(AD) Wasserhärte zu hoch","warn"],
                "0x0D" => ["(0D) Salz leer","warn"],
                "0x0E" => ["(0E) Ventilposition falsch","alarm"],
            ];
            return $map[$hex] ?? ["Unbekannt ($hex)","warn"];
        }
        // ---------------------------------------------------
        // WARNUNG
        // ---------------------------------------------------
        function decodeWarning($hex) {
            if (!$hex || strtolower($hex) == "ff") return ["(FF) Keine aktuelle Warnung","ok"];
            $hex = strtoupper(trim((string)$hex));
            if (strpos($hex, "0X") !== 0) $hex = "0x".$hex;
            $map = [
                "0x01" => ["(01) Stromunterbrechung","warn"],
                "0x07" => ["(07) Leckagewarnung Volumen","warn"],
                "0x08" => ["(08) Batterie leer","warn"],
                "0x02" => ["(02) Salz niedrig","warn"],
                "0x09" => ["(09) Erstbefüllung erforderlich","warn"],
                "0x10" => ["(10) Volumenleck erkannt","warn"],
                "0x11" => ["(11) Zeitleck erkannt","warn"],
            ];
            return $map[$hex] ?? ["Warnung ($hex)","warn"];
        }
        // ---------------------------------------------------
        // NOTIFICATION
        // ---------------------------------------------------
        function decodeNotification($hex) {
            if (!$hex || strtolower($hex) == "ff") return ["(FF) Keine aktuelle Meldung","ok"];
            $hex = strtoupper(trim((string)$hex));
            if (strpos($hex, "0X") !== 0) $hex = "0x".$hex;
            $map = [
                "0x01" => ["(01) Softwareupdate verfügbar","warn"],
                "0x04" => ["(04) Softwareupdate installiert","ok"],
                "0x02" => ["(02) Halbjährliche Wartung","warn"],
                "0x03" => ["(03) Jährliche Wartung","warn"],
            ];
            return $map[$hex] ?? ["Info ($hex)","warn"];
        }
        function decodeMicroStatus($val) {
            return match((int)$val) {
                0 => ["Nicht aktiv", "secondary"],
                1 => ["Test aktiv", "warning"],
                2 => ["Abgebrochen (Druckabfall)", "danger"],
                3 => ["Übersprungen", "info"],
                default => ["Unbekannt", "dark"]
            };
        }
        // ---------------------------------------------------
        // WLAN Status
        // ---------------------------------------------------
        function decodeWifiStatus($wfs) {
            switch ((string)$wfs) {
                case '0': return "Nicht verbunden";
                case '1': return "Verbinden...";
                case '2': return "Verbunden";
                default:  return "-";
            }
        }
 

        /*
         * Abgeleitete Werte wie im alten Template
         */
        $zwzPower = '0';
        $zwzPowerUnit = 'kW';
        if (isset($d['ZWZZaehlerPowerIn'], $d['ZWZZaehlerPowerOut'])) {
            $zwzPower = round( coh_num($d['ZWZZaehlerPowerOut']['sensorValue']) - coh_num($d['ZWZZaehlerPowerIn']['sensorValue']),2);
            $zwzPowerUnit = $d['ZWZZaehlerPowerIn']['sensorEinheit'] ?? 'kW';
        }
        $tasmotaPower = '0';
        $tasmotaPowerUnit = 'kW';
        if (isset($d['ZWZZaehlerPowerIn'], $d['ZWZZaehlerPowerOut'])) {
            $tasmotaPower = round( coh_num($d['TS_E_out_208']['sensorValue']) - coh_num($d['TS_E_in_108']['sensorValue']),2);
            $tasmotaPowerUnit = $d['TS_E_in_108']['sensorEinheit'] ?? 'kW';
        }
        $zwzTotal = '-';
        $zwzTotalUnit = 'kWh';
        if (isset($d['ZWZZaehlerTotalPVEnergieImport'], $d['ZWZZaehlerTotalPVEnergieExport'])) {
            $imp = $d['ZWZZaehlerTotalPVEnergieImport']['sensorValue'] ?? '-';
            $exp = $d['ZWZZaehlerTotalPVEnergieExport']['sensorValue'] ?? '-';
            $zwzTotal = $imp.'/'.$exp;
            $zwzTotalUnit = $d['ZWZZaehlerTotalPVEnergieImport']['sensorEinheit'] ?? 'kWh';
        }
        $batteryPercent = coh_num(coh_v($d, 'IQbattery_94_battery_stateOfCharge', 0), 0);
        $batteryPower   = coh_num(coh_v($d, 'IQbattery_94_battery_power', 0), 0);
        $boostValue     = coh_num(coh_v($d, 'ELaktboostactive', 0), 0);
        $heizstabServerOk = coh_num(coh_v($d, 'RaspberryCheckHeizstabServer', -1), -1) >= 0;
        $collectorServerVal = (string) coh_v($d, 'RaspberrycheckSensorCollectorServer', '-');
        $plattenText = '';
        $plattenRaw = coh_v($d, 'RaspberrycheckPlattenbelegung', '');
        if ($plattenRaw && $plattenRaw !== '-') {
            $parsed = json_decode((string) $plattenRaw, true);
            if (is_array($parsed)) {
                $lines = [];
                foreach ($parsed as $item) {
                    if (is_array($item)) {
                        foreach ($item as $k => $v) { $lines[] = $k.': '.$v; }
                    }
                }
                $plattenText = implode(' | ', $lines);
            } else {
                $plattenText = (string) $plattenRaw;
            }
        }
        $protokollText = (string) coh_v($d, 'RaspberryHeizstabServerProtokoll', '-');
        $protokollHasError = preg_match('/error|fehler/i', $protokollText) === 1;
        $akkuPowerClass = $batteryPower >= 0 ? 'is-green' : 'is-red';
        $boostClass = 'is-gray';
        if ($boostValue < 0) { $boostClass = 'is-red';
        } elseif ($boostValue == 0) { $boostClass = 'is-gray';
        } elseif ($boostValue == 1 || $boostValue == 2) { $boostClass = 'is-green';
        } elseif ($boostValue > 2) { $boostClass = 'is-blue';
        }
        // ---------------------------------------------------
        // BERECHNUNG werte berechnung Wasser Leckage
        // ---------------------------------------------------
        // Ventil 
        $SYR_vlv = coh_v($d, 'SyrVlv');
        $SYR_valve = [  10 => "ZU", 11 => "am Schließen", 20 => "OFFEN", 21 => "am Öffnen"][$SYR_vlv] ?? "UNBEKANNT $SYR_vlv";
        $SYR_cl = [  10 => "is-red", 11 => "is-orange", 20 => "is-green", 21 => "is-orange"][$SYR_vlv] ?? "is-blue";
        // ---------------------------------------------------
        // STATUS
        // ---------------------------------------------------
        $SYR_arr = decodeAlarm(coh_v($d, 'SyrAla') ?? null);
        switch ($SYR_arr[1]) {
            case 'ok':
                $SYR_alarmStatus = 'OK';
                $SYR_clalarmStatus = 'is-green';
                $SYR_alarm_lamp = '🟢';
                break;
            case 'warn':
                $SYR_alarmStatus = 'WARNUNG';
                $SYR_clalarmStatus = 'is-orange';
                $SYR_alarm_lamp = '🟡';
                break;
            case 'alarm':
                $SYR_alarmStatus = 'ALARM';
                $SYR_clalarmStatus = 'is-red';
                $SYR_alarm_lamp = '🔴';
                break;
            default:
                $SYR_alarmStatus = 'UNBEKANNT ' . $SYR_arr[0];
                $SYR_clalarmStatus = 'is-red';
                $SYR_alarm_lamp = '🔴';
                break;
        }
        $leak = detectLeakType($d);
        $leaktxt= '<br>'.$leak['text'];
        $SYR_batVolt = coh_num(coh_v($d, 'SyrBat'), 0);
        $SYR_batPercent = max(0, min(100, round(($SYR_batVolt - 4.9) / (6.2 - 4.9) * 100)));   // 6.2 V voll 4.2V leer
        $SYR_batPercenttxt="<div class='big'>$SYR_batPercent % </div>";
        $SYR_leitWert = coh_num(coh_v($d, 'SyrCnd',0));
        $dH = round($SYR_leitWert/30,2);
        /* noch offen
            $temp = isset($data["CEL"]) ? ($data["CEL"] / 10) : 0;
            // Button-Zustände
            $disableOpen  = ($SYR_vlv == 20 || $SYR_vlv == 21);
            $disableClose = ($SYR_vlv == 10 || $SYR_vlv == 11);
        */
        function renderMinibox ($cl,$label,$value) {
            $str = "";
            $str .= "<div class='coh-mini-box $cl'>";
            $str .= "<div class='coh-mini-label'>$label</div>";
            $str .= "<div class='coh-mini-value'>$value</div>";
            $str .= "</div>";
            return $str;
        }
