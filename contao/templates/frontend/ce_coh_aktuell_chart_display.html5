    <script>
        document.addEventListener('DOMContentLoaded', function () {
            function initGauge_<?= $this->chartId ?>(retry) {
                retry = retry || 0;
                if (typeof window.RadialGauge === 'undefined') {
                    if (retry < 30) {
                        setTimeout(function () {
                            initGauge_<?= $this->chartId ?>(retry + 1);
                        }, 100);
                    }
                    return;
                }
                var canvasId = 'cohGauge_<?= $this->chartId ?>';
                var canvas = document.getElementById(canvasId);
                if (!canvas) {
                    return;
                }
                var gauge = new RadialGauge({
                    renderTo: canvasId,
                    width: 90,
                    height: 90,
                    value: <?= json_encode($batteryPercent) ?>,
                    units: "%",
                    startAngle: 180,
                    ticksAngle: 360,
                    minValue: 0,
                    maxValue: 100,
                    barWidth: 15,
                    colorBarProgress: '#00cc00',
                    colorBar: 'blue',
                    needleType: 'arrow',
                    needleWidth: 10,
                    needleCircleSize: 1,
                    needleCircleOuter: true,
                    needleCircleInner: false,
                    colorNeedle: 'red',
                    colorNeedleEnd: 'red',
                    valueBox: false,
                    strokeTicks: false,
                    colorNumbers: 'transparent',
                    colorMajorTicks: 'transparent',
                    colorMinorTicks: 'transparent',
                    majorTicks: [],
                    minorTicks: 0,
                    colorPlate: 'transparent',
                    borders: false,
                    borderOuterWidth: 0,
                    borderMiddleWidth: 0,
                    borderInnerWidth: 0,
                    borderShadowWidth: 0,
                    highlights: [],
                    animation: false,
                    highDpiSupport: true        
                });
                gauge.draw();
            }
            initGauge_<?= $this->chartId ?>(0);
        });
    </script>
</div>