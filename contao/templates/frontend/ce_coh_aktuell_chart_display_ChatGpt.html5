<div id="cohPanel_<?= $this->chartId ?>" class="coh-panel">

<?php
$d = $this->data ?? [];

if (!function_exists('coh_v')) {
    function coh_v(array $d, string $id, $default = '-')
    {
        return $d[$id]['sensorValue'] ?? $default;
    }
}

if (!function_exists('coh_e')) {
    function coh_e(array $d, string $id, string $default = '')
    {
        return $d[$id]['sensorEinheit'] ?? $default;
    }
}

if (!function_exists('coh_title')) {
    function coh_title(array $d, string $id, string $default = '')
    {
        return $d[$id]['sensorTitle'] ?? $default;
    }
}

if (!function_exists('coh_num')) {
    function coh_num($value, $default = 0.0): float
    {
        if ($value === null || $value === '' || $value === '-') {
            return (float) $default;
        }
        return (float) str_replace(',', '.', (string) $value);
    }
}

/*
 * Abgeleitete Werte wie im alten Template
 */
$zwzPower = '-';
$zwzPowerUnit = 'kW';
if (isset($d['ZWZZaehlerPowerIn'], $d['ZWZZaehlerPowerOut'])) {
    $zwzPower = round(
        coh_num($d['ZWZZaehlerPowerOut']['sensorValue']) - coh_num($d['ZWZZaehlerPowerIn']['sensorValue']),
        2
    );
    $zwzPowerUnit = $d['ZWZZaehlerPowerIn']['sensorEinheit'] ?? 'kW';
}

$zwzTotal = '-';
$zwzTotalUnit = 'kWh';
if (isset($d['ZWZZaehlerTotalPVEnergieImport'], $d['ZWZZaehlerTotalPVEnergieExport'])) {
    $imp = $d['ZWZZaehlerTotalPVEnergieImport']['sensorValue'] ?? '-';
    $exp = $d['ZWZZaehlerTotalPVEnergieExport']['sensorValue'] ?? '-';
    $zwzTotal = $imp.'/'.$exp;
    $zwzTotalUnit = $d['ZWZZaehlerTotalPVEnergieImport']['sensorEinheit'] ?? 'kWh';
}

$batteryPercent = coh_num(coh_v($d, 'IQbattery_94_battery_stateOfCharge', 0), 0);
$batteryPower   = coh_num(coh_v($d, 'IQbattery_94_battery_power', 0), 0);
$boostValue     = coh_num(coh_v($d, 'ELaktboostactive', 0), 0);

$heizstabServerOk = coh_num(coh_v($d, 'RaspberryCheckHeizstabServer', -1), -1) >= 0;
$collectorServerVal = (string) coh_v($d, 'RaspberrycheckSensorCollectorServer', '-');

$plattenText = '';
$plattenRaw = coh_v($d, 'RaspberrycheckPlattenbelegung', '');
if ($plattenRaw && $plattenRaw !== '-') {
    $parsed = json_decode((string) $plattenRaw, true);
    if (is_array($parsed)) {
        $lines = [];
        foreach ($parsed as $item) {
            if (is_array($item)) {
                foreach ($item as $k => $v) {
                    $lines[] = $k.': '.$v;
                }
            }
        }
        $plattenText = implode(' | ', $lines);
    } else {
        $plattenText = (string) $plattenRaw;
    }
}

$protokollText = (string) coh_v($d, 'RaspberryHeizstabServerProtokoll', '-');
$protokollHasError = preg_match('/error|fehler/i', $protokollText) === 1;

$akkuPowerClass = $batteryPower >= 0 ? 'is-green' : 'is-red';

$boostClass = 'is-gray';
if ($boostValue < 0) {
    $boostClass = 'is-red';
} elseif ($boostValue == 0) {
    $boostClass = 'is-gray';
} elseif ($boostValue == 1 || $boostValue == 2) {
    $boostClass = 'is-green';
} elseif ($boostValue > 2) {
    $boostClass = 'is-blue';
}
?>

<style>
