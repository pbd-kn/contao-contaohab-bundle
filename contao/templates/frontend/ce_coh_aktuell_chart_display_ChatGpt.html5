<script>
document.addEventListener('DOMContentLoaded', function () {
    function initGauge_<?= $this->chartId ?>(retry) {
        retry = retry || 0;

        if (typeof window.RadialGauge === 'undefined') {
            if (retry < 30) {
                setTimeout(function () {
                    initGauge_<?= $this->chartId ?>(retry + 1);
                }, 100);
            }
            return;
        }

        var canvasId = 'cohGauge_<?= $this->chartId ?>';
        var canvas = document.getElementById(canvasId);
        if (!canvas) {
            return;
        }

        var gauge = new RadialGauge({
            renderTo: canvasId,
            width: 90,
            height: 90,
            minValue: 0,
            maxValue: 100,
            value: <?= json_encode($batteryPercent) ?>,
            units: "%",
            exactTicks: false,
            majorTicks: ["0", "20", "40", "60", "80", "100"],
            minorTicks: 2,
            strokeTicks: true,
            highlights: [
                { from: 0, to: 20, color: "rgba(198,40,40,.25)" },
                { from: 20, to: 60, color: "rgba(201,122,0,.20)" },
                { from: 60, to: 100, color: "rgba(23,138,47,.20)" }
            ],
            colorPlate: "#ffffff",
            borderShadowWidth: 0,
            borders: true,
            needleType: "arrow",
            needleWidth: 3,
            needleCircleSize: 7,
            needleCircleOuter: true,
            needleCircleInner: false,
            animationDuration: 500,
            animationRule: "linear",
            colorMajorTicks: "#666",
            colorMinorTicks: "#888",
            colorTitle: "#333",
            colorUnits: "#333",
            colorNumbers: "#333",
            colorNeedle: "#cc3333",
            colorNeedleEnd: "#cc3333",
            colorBarProgress: "#2b6cf0",
            colorBar: "#e5e7eb",
            fontNumbersSize: 18,
            fontUnitsSize: 20,
            fontTitleSize: 0
        });

        gauge.draw();
    }

    initGauge_<?= $this->chartId ?>(0);
});
</script>

</div>