<div id="syr-dashboard">

    <div class="grid">

        <!-- Ventil -->
        <div class="card">
            <div>🚰 Ventil</div>
            <div class="big" id="valveState"><?= $this->valve ?></div>

            <div style="margin-top:10px; display:flex; gap:5px;">
                <button class="btn btn-open" onclick="syrAction('open')">Öffnen</button>
                <button class="btn btn-close" onclick="syrAction('close')">Schließen</button>
            </div>

            <div id="waitingNote" class="waiting-note"></div>
        </div>

        <!-- Status -->
        <div class="card">
            <div>AlarmStatus</div>
            <div class="big"><?= $this->status ?></div>
        </div>

        <!-- Batterie -->
        <div class="card">
            <div>Batterie</div>
            <div class="big"><?= $this->batPercent ?> %</div>
            <div><?= $this->batVolt ?> V</div>
        </div>

        <!-- Durchfluss -->
        <div class="card">
            <div>💧 Durchfluss</div>
            <div class="big"><?= $this->flow ?> l/h</div>
        </div>

        <!-- Profil -->
        <div class="card">
            <div>⚙️Profil</div>
            <div class="big" id="profileVal"><?= $this->prf ?></div>

            <select id="profileSelect">
                <?php for($i=1;$i<=8;$i++): ?>
                    <option value="<?= $i ?>" <?= $i==$this->prf?'selected':'' ?>><?= $i ?></option>
                <?php endfor; ?>
            </select>

            <button onclick="setProfile()">OK</button>
        </div>

    </div>

</div>

<script>

const API = "/api/syr?token=COH_CODE";

function syrAction(action)
{
    if (!confirm("Wirklich ausführen?")) return;

    lockUI("⏳ Warte auf Ventil (~50s)...");

    fetch(API + "&action=" + action)
        .then(r => r.json())
        .then(data => {

            unlockUI();

            if (data.success) {
                document.getElementById("valveState").innerText =
                    (data.vlv == 20 ? "OFFEN" : "ZU");
            } else {
                alert("Fehler");
            }

        });
}

function setProfile()
{
    let p = document.getElementById("profileSelect").value;

    fetch(API + "&action=setProfile&profile=" + p)
        .then(r => r.json())
        .then(data => {

            if (data.success) {
                document.getElementById("profileVal").innerText = p;
            } else {
                alert("Fehler beim Setzen");
            }

        });
}

// ----------------------------------
// UI LOCK
// ----------------------------------
function lockUI(text)
{
    document.body.style.cursor = 'wait';

    document.querySelectorAll("button").forEach(b => {
        b.disabled = true;
    });

    document.getElementById("waitingNote").innerText = text;
}

function unlockUI()
{
    document.body.style.cursor = 'default';

    document.querySelectorAll("button").forEach(b => {
        b.disabled = false;
    });

    document.getElementById("waitingNote").innerText = "";
}

</script>